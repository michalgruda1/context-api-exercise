{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowArbitraryExtensions": true,
    "jsx": "react-jsx",
    "baseUrl": "src",
    "ignoreDeprecations": "6.0",
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
